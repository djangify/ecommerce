---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { fetchProducts, fetchCategories } from "../lib/api";

const featuredProducts = await fetchProducts();
const categories = await fetchCategories();
---

<BaseLayout>
	<Header slot="header" />

	<section class="bg-blue-600 py-16 text-white">
		<div class="container mx-auto px-4 text-center">
			<h1 class="text-4xl md:text-5xl font-bold mb-4">Welcome to Our Shop</h1>
			<p class="text-xl mb-8">Discover our amazing products</p>

			href="/products" class="bg-white text-blue-600 hover:bg-blue-100
			transition-colors duration-300 font-medium py-3 px-6 rounded-full" > Shop
			Now
		</div>
	</section>
</BaseLayout>

<!-- Featured Products Section -->
<section class="py-16">
	<div class="container mx-auto px-4">
		<h2 class="text-3xl font-bold mb-8 text-center">Featured Products</h2>
		<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
			{
				featuredProducts.slice(0, 4).map((product) => (
					<a
						href={`/products/${product.slug}`}
						class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow"
					>
						{product.main_image && (
							<img
								src={product.main_image}
								alt={product.name}
								class="w-full h-48 object-cover"
							/>
						)}
						<div class="p-4">
							<h3 class="text-lg font-semibold mb-2">{product.name}</h3>
							<div class="flex justify-between items-center">
								<span class="text-lg font-bold text-blue-600">
									${product.current_price}
								</span>
								{product.is_on_sale && (
									<span class="text-sm line-through text-gray-500">
										${product.price}
									</span>
								)}
							</div>
						</div>
					</a>
				))
			}
		</div>
		<div class="text-center mt-8">
			href="/products" class="inline-block bg-blue-600 text-white py-2 px-6
			rounded-md hover:bg-blue-700 transition-colors" > View All Products
		</div>
	</div>
</section>

<Footer slot="footer" />
