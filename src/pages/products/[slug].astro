---
// src/pages/products/[slug].astro - Fixed implementation
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { fetchProduct, fetchProducts } from "../../lib/api";
import type { Product } from "../../types";

// Add error handling for static paths generation
export async function getStaticPaths() {
  let products = [];
  try {
    products = await fetchProducts();
  } catch (error) {
    console.error("Error fetching products for static paths:", error);
    // Return at least one path to prevent build failures
    return [
      {
        params: { slug: "sample-product" },
        props: {
          product: {
            id: "sample",
            name: "Sample Product",
            slug: "sample-product",
            description: "This is a sample product description.",
            price: 29.99,
            sale_price: null,
            current_price: 29.99,
            is_on_sale: false,
            is_featured: true,
            in_stock: true,
            stock_qty: 10,
            sku: "SAMPLE001",
            main_image: "/api/placeholder/400/320",
            images: [],
            variants: [],
            category: {
              id: "1",
              name: "Sample Category",
              slug: "sample-category",
              description: null,
              image: null,
            },
          },
          isError: true,
        },
      },
    ];
  }

  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product, isError: false },
  }));
}

const { product, isError } = Astro.props;

// Fetch the full product data for more details if this is a dynamic route
let fullProduct = product;
if (!isError && Astro.request.url.includes(product.slug)) {
  try {
    fullProduct = await fetchProduct(product.slug);
  } catch (error) {
    console.error(
      `Error fetching full product data for ${product.slug}:`,
      error,
    );
    // We'll continue with the basic product data we already have
  }
}
---

<BaseLayout title={`${product.name} | Todiane Shop`}>
  <Header slot="header" />

  <div class="container mx-auto px-4 py-12">
    {
      isError ? (
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-8">
          <p class="text-yellow-700">
            Currently showing sample product data. Connect to your API to see
            actual products.
          </p>
        </div>
      ) : null
    }

    <div class="flex flex-col md:flex-row mb-12">
      <!-- Product Images -->
      <div class="w-full md:w-1/2 mb-8 md:mb-0">
        <div class="bg-white p-4 rounded-lg shadow-md">
          <img
            src={fullProduct.main_image || "/api/placeholder/400/320"}
            alt={fullProduct.name}
            class="w-full h-auto rounded-lg"
          />

          {
            fullProduct.images && fullProduct.images.length > 0 && (
              <div class="grid grid-cols-4 gap-2 mt-4">
                {fullProduct.images.map((image) => (
                  <img
                    src={image.image || "/api/placeholder/100/100"}
                    alt={image.alt_text || fullProduct.name}
                    class="w-full h-20 object-cover rounded-md cursor-pointer"
                  />
                ))}
              </div>
            )
          }
        </div>
      </div>

      <!-- Product Info -->
      <div class="w-full md:w-1/2 md:pl-8">
        <h1 class="text-3xl font-bold mb-4">{fullProduct.name}</h1>

        <div class="mb-4">
          {
            fullProduct.is_on_sale ? (
              <div class="flex items-center">
                <span class="text-2xl font-bold text-blue-600 mr-2">
                  ${fullProduct.current_price}
                </span>
                <span class="text-lg line-through text-gray-500">
                  ${fullProduct.price}
                </span>
                <span class="ml-2 bg-red-100 text-red-800 text-xs font-semibold px-2 py-1 rounded">
                  SALE
                </span>
              </div>
            ) : (
              <span class="text-2xl font-bold text-blue-600">
                ${fullProduct.price}
              </span>
            )
          }
        </div>

        <div class="mb-6">
          <span
            class={`${fullProduct.in_stock ? "text-green-600" : "text-red-600"} font-medium`}
          >
            {fullProduct.in_stock ? "In Stock" : "Out of Stock"}
          </span>
          {
            fullProduct.in_stock && (
              <span class="text-gray-600 ml-2">
                ({fullProduct.stock_qty} available)
              </span>
            )
          }
        </div>

        {
          fullProduct.variants && fullProduct.variants.length > 0 && (
            <div class="mb-6">
              <label class="block text-gray-700 font-medium mb-2">
                Options
              </label>
              <select
                id="variant-select"
                class="w-full p-2 border border-gray-300 rounded-md"
              >
                <option value="">Select an option</option>
                {fullProduct.variants.map((variant) => (
                  <option value={variant.id}>
                    {variant.attributes
                      ?.map((attr) => attr.value)
                      .join(" / ") || "Standard"}{" "}
                    - ${variant.price}
                  </option>
                ))}
              </select>
            </div>
          )
        }

        <div class="mb-6">
          <label class="block text-gray-700 font-medium mb-2"> Quantity </label>
          <div class="flex items-center">
            <button
              class="bg-gray-200 px-3 py-1 rounded-l-md"
              id="decrease-qty"
            >
              -
            </button>
            <input
              type="number"
              min="1"
              value="1"
              id="quantity"
              class="w-16 text-center border-t border-b border-gray-300 py-1"
            />
            <button
              class="bg-gray-200 px-3 py-1 rounded-r-md"
              id="increase-qty"
            >
              +
            </button>
          </div>
        </div>

        <button
          id="add-to-cart"
          class="w-full bg-blue-600 text-white py-3 px-4 rounded-md hover:bg-blue-700 transition-colors mb-4"
          data-product-id={fullProduct.id}
        >
          Add to Cart
        </button>

        <div class="prose max-w-none mt-8">
          <h3 class="text-xl font-semibold mb-2">Description</h3>
          <div set:html={fullProduct.description} />
        </div>
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<script define:vars={{ productId: product.id }}>
  // Quantity buttons
  const decreaseBtn = document.getElementById("decrease-qty");
  const increaseBtn = document.getElementById("increase-qty");
  const quantityInput = document.getElementById("quantity");
  const addToCartBtn = document.getElementById("add-to-cart");
  const variantSelect = document.getElementById("variant-select");

  if (decreaseBtn && increaseBtn && quantityInput) {
    decreaseBtn.addEventListener("click", () => {
      const currentValue = parseInt(quantityInput.value);
      if (currentValue > 1) {
        quantityInput.value = currentValue - 1;
      }
    });

    increaseBtn.addEventListener("click", () => {
      const currentValue = parseInt(quantityInput.value);
      quantityInput.value = currentValue + 1;
    });
  }

  if (addToCartBtn) {
    addToCartBtn.addEventListener("click", async () => {
      const quantity = parseInt(quantityInput.value);
      const variantId = variantSelect ? variantSelect.value : null;

      try {
        const response = await fetch(`/api/cart/add`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            productId,
            variantId: variantId || undefined,
            quantity,
          }),
        });

        if (response.ok) {
          const result = await response.json();
          alert("Product added to cart!");
          console.log("Added to cart:", result);
        } else {
          const error = await response.json();
          alert(
            "Failed to add product to cart: " +
              (error.error || "Unknown error"),
          );
        }
      } catch (error) {
        console.error("Error adding to cart:", error);
        alert("An error occurred. Please try again.");
      }
    });
  }
</script>
