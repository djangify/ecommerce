---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const orderId = Astro.url.searchParams.get("order_id");
const paymentIntent = Astro.url.searchParams.get("payment_intent");
const paymentStatus = Astro.url.searchParams.get("redirect_status");

// You would typically fetch order details from your API here
// For now, we'll just display the order ID
---

<BaseLayout>
  <Header slot="header" />

  <div class="container mx-auto px-4 py-12">
    <div
      class="bg-white rounded-lg shadow-md p-8 max-w-2xl mx-auto text-center"
    >
      {
        paymentStatus === "succeeded" ? (
          <>
            <div class="w-16 h-16 mx-auto bg-green-100 rounded-full flex items-center justify-center mb-6">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8 text-green-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
            </div>
            <h1 class="text-3xl font-bold mb-4">Order Confirmed!</h1>
            <p class="text-gray-600 mb-6">
              Thank you for your purchase. Your order has been confirmed and
              will be shipped soon.
            </p>
            <p class="mb-6">
              <span class="font-medium">Order ID:</span> {orderId}
            </p>
            <p class="text-sm text-gray-500 mb-8">
              A confirmation email has been sent to your email address.
            </p>
            <div class="flex justify-center space-x-4">
              <a
                href="/products"
                class="bg-blue-600 text-white py-2 px-6 rounded-md hover:bg-blue-700 transition-colors"
              >
                Continue Shopping
              </a>
            </div>
          </>
        ) : (
          <>
            <div class="w-16 h-16 mx-auto bg-yellow-100 rounded-full flex items-center justify-center mb-6">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-8 w-8 text-yellow-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                />
              </svg>
            </div>
            <h1 class="text-3xl font-bold mb-4">Payment Processing</h1>
            <p class="text-gray-600 mb-6">
              Your payment is being processed. We'll update you on the status
              shortly.
            </p>
            <p class="mb-6">
              <span class="font-medium">Order ID:</span> {orderId}
            </p>
            <p class="text-sm text-gray-500 mb-8">
              If you have any questions, please contact our customer support.
            </p>
            <div class="flex justify-center space-x-4">
              <a
                href="/products"
                class="bg-blue-600 text-white py-2 px-6 rounded-md hover:bg-blue-700 transition-colors"
              >
                Continue Shopping
              </a>
            </div>
          </>
        )
      }
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>
