---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { fetchCart } from "../../lib/api";

const getDefaultCart = () => ({
  id: "0",
  items: [],
  subtotal: 0,
  total_items: 0,
  created_at: new Date().toISOString(),
});

let cart;
try {
  cart = await fetchCart();
} catch {
  cart = getDefaultCart();
}
if (!cart) cart = getDefaultCart();

const safeCart = {
  id: cart.id || "0",
  items: Array.isArray(cart.items) ? cart.items : [],
  subtotal: cart.subtotal || 0,
  total_items: cart.total_items || 0,
  created_at: cart.created_at || new Date().toISOString(),
};
---

<BaseLayout title="Your Cart | Todiane Shop">
  <Header slot="header" />
  … your table / markup here …
  <Footer slot="footer" />
</BaseLayout>

<!-- client-side script to update / remove items -->
<script type="module">
  const API = import.meta.env.VITE_PUBLIC_API_URL;

  async function updateCartItem(itemId, quantity) {
    const res = await fetch(`${API}/api/v1/items/${itemId}/`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      credentials: "include",
      body: JSON.stringify({ quantity }),
    });
    if (!res.ok) throw new Error("Failed to update cart");
    return res.json();
  }

  async function removeCartItem(itemId) {
    const res = await fetch(`${API}/api/v1/items/${itemId}/`, {
      method: "DELETE",
      credentials: "include",
    });
    if (!res.ok) throw new Error("Failed to remove item");
  }

  document.addEventListener("DOMContentLoaded", () => {
    // increase
    document.querySelectorAll('[data-action="increase"]').forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-item-id");
        if (!id) return;
        const input = document.querySelector(`input[data-item-id="${id}"]`);
        if (!(input instanceof HTMLInputElement)) return;
        const oldQty = +input.value;
        input.value = String(oldQty + 1);
        try {
          await updateCartItem(id, oldQty + 1);
        } catch {
          input.value = String(oldQty);
        }
      });
    });

    // decrease
    document.querySelectorAll('[data-action="decrease"]').forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-item-id");
        if (!id) return;
        const input = document.querySelector(`input[data-item-id="${id}"]`);
        if (!(input instanceof HTMLInputElement)) return;
        const oldQty = +input.value;
        if (oldQty > 1) {
          input.value = String(oldQty - 1);
          try {
            await updateCartItem(id, oldQty - 1);
          } catch {
            input.value = String(oldQty);
          }
        }
      });
    });

    // remove
    document.querySelectorAll('[data-action="remove"]').forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-item-id");
        if (!id || !confirm("Remove this item?")) return;
        try {
          await removeCartItem(id);
          window.location.reload();
        } catch {
          alert("Failed to remove item.");
        }
      });
    });
  });
</script>
