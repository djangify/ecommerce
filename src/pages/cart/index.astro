---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { fetchCart } from "../../lib/api";

const getDefaultCart = () => ({
  id: "0",
  items: [],
  subtotal: 0,
  total_items: 0,
  created_at: new Date().toISOString(),
});

let cart;
try {
  cart = await fetchCart();
} catch {
  cart = getDefaultCart();
}
if (!cart) cart = getDefaultCart();

const safeCart = {
  id: cart.id || "0",
  items: Array.isArray(cart.items) ? cart.items : [],
  subtotal: cart.subtotal || 0,
  total_items: cart.total_items || 0,
  created_at: cart.created_at || new Date().toISOString(),
};
const API = import.meta.env.VITE_PUBLIC_API_URL;
---

<BaseLayout title="Your Cart | Todiane Shop">
  <Header slot="header" />
  
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8">Your Cart</h1>

    {safeCart.items.length === 0 ? (
      <div class="bg-white p-8 rounded-lg shadow-md text-center">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-16 w-16 mx-auto mb-4 text-gray-400"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"
          />
        </svg>
        <h2 class="text-2xl font-semibold mb-4">Your cart is empty</h2>
        <p class="text-gray-600 mb-6">
          Looks like you haven't added any products to your cart yet.
        </p>
        
        <a 
          href="/products"
          class="inline-block bg-blue-600 text-white py-2 px-6 rounded-md hover:bg-blue-700 transition-colors"
        >
          Continue Shopping
        </a>
      </div>
    ) : (
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Cart Items -->
        <div class="lg:w-2/3">
          <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Product
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Price
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Quantity
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Total
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                    Actions
                  </th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {safeCart.items.map((item: any) => (
                  <tr>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex items-center">
                        <div class="h-16 w-16 flex-shrink-0">
                          <img 
                            class="h-16 w-16 object-cover" 
                            src={item?.product?.main_image || '/images/no-image.svg'} 
                            alt={item?.product?.name || 'Product'} 
                          />
                        </div>
                        <div class="ml-4">
                          <div class="text-sm font-medium text-gray-900">
                            {item?.product?.name || 'Unknown Product'}
                          </div>
                          {item?.variant && item?.variant?.attributes && (
                            <div class="text-sm text-gray-500">
                              {item.variant.attributes.map((attr: any) => attr?.value || '').filter(Boolean).join(' / ')}
                            </div>
                          )}
                        </div>
                      </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-900">${item?.unit_price || '0.00'}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex items-center">
                        <button
                          class="bg-gray-200 px-2 py-1 rounded-l-md"
                          data-action="decrease"
                          data-item-id={item?.id || ''}
                        >
                          -
                        </button>
                        <input
                          type="number"
                          min="1"
                          value={item?.quantity || 1}
                          class="w-12 text-center border-t border-b border-gray-300 py-1"
                          data-item-id={item?.id || ''}
                        />
                        <button
                          class="bg-gray-200 px-2 py-1 rounded-r-md"
                          data-action="increase"
                          data-item-id={item?.id || ''}
                        >
                          +
                        </button>
                      </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm text-gray-900">${item?.total_price || '0.00'}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <button
                        class="text-red-600 hover:text-red-900"
                        data-action="remove"
                        data-item-id={item?.id || ''}
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Order Summary -->
        <div class="lg:w-1/3">
          <div class="bg-white rounded-lg shadow-md p-6">
            <h2 class="text-xl font-semibold mb-4">Order Summary</h2>
            <div class="space-y-4">
              <div class="flex justify-between">
                <span>Subtotal</span>
                <span>${safeCart.subtotal}</span>
              </div>
              <div class="flex justify-between">
                <span>Shipping</span>
                <span>Calculated at checkout</span>
              </div>
              <div class="flex justify-between border-t border-gray-200 pt-4 font-semibold">
                <span>Total</span>
                <span>${safeCart.subtotal}</span>
              </div>
            </div>
            <a 
              href="/checkout" 
              class="w-full block text-center bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition-colors mt-6"
            >
              Proceed to Checkout
            </a>
            <a 
              href="/products" 
              class="w-full block text-center text-blue-600 py-2 px-4 mt-4"
            >
              Continue Shopping
            </a>
          </div>
        </div>
      </div>
    )}
  </div>
  <Footer slot="footer" />
</BaseLayout>

<!-- client-side script to update / remove items -->
<script type="module">
  const API = import.meta.env.VITE_PUBLIC_API_URL;

  async function updateCartItem(itemId, quantity) {
    const res = await fetch(`${API}/api/v1/items/${itemId}/`, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      credentials: "include",
      body: JSON.stringify({ quantity }),
    });
    if (!res.ok) throw new Error("Failed to update cart");
    return res.json();
  }

  async function removeCartItem(itemId) {
    const res = await fetch(`${API}/api/v1/items/${itemId}/`, {
      method: "DELETE",
      credentials: "include",
    });
    if (!res.ok) throw new Error("Failed to remove item");
  }

  document.addEventListener("DOMContentLoaded", () => {
    // increase
    document.querySelectorAll('[data-action="increase"]').forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-item-id");
        if (!id) return;
        const input = document.querySelector(`input[data-item-id="${id}"]`);
        if (!(input instanceof HTMLInputElement)) return;
        const oldQty = +input.value;
        input.value = String(oldQty + 1);
        try {
          await updateCartItem(id, oldQty + 1);
        } catch {
          input.value = String(oldQty);
        }
      });
    });

    // decrease
    document.querySelectorAll('[data-action="decrease"]').forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-item-id");
        if (!id) return;
        const input = document.querySelector(`input[data-item-id="${id}"]`);
        if (!(input instanceof HTMLInputElement)) return;
        const oldQty = +input.value;
        if (oldQty > 1) {
          input.value = String(oldQty - 1);
          try {
            await updateCartItem(id, oldQty - 1);
          } catch {
            input.value = String(oldQty);
          }
        }
      });
    });

    // remove
    document.querySelectorAll('[data-action="remove"]').forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-item-id");
        if (!id || !confirm("Remove this item?")) return;
        try {
          await removeCartItem(id);
          window.location.reload();
        } catch {
          alert("Failed to remove item.");
        }
      });
    });
  });
</script>
