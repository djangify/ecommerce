---
const year = new Date().getFullYear();
---

<footer class="bg-gray-50 mx-auto text-center border-t">
  <div class="container px-4 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center">
      <div>
        <a href="/" class="text-blue-600 font-bold text-xl">Todiane Shop</a>
        <p class="text-gray-600 mt-2">Your trusted online shop</p>
      </div>
      <div class="mt-4 md:mt-0">
        <nav class="flex space-x-4">
          <a href="/products" class="text-gray-600 hover:text-blue-600"
            >Products</a
          >
          <a href="/cart" class="text-gray-600 hover:text-blue-600">Cart</a>
          <a href="/about" class="text-gray-600 hover:text-blue-600">About</a>
          <a href="/contact" class="text-gray-600 hover:text-blue-600"
            >Contact</a
          >
        </nav>
      </div>
    </div>
    <div class="border-t border-gray-200 mt-6 pt-6 text-sm text-gray-500">
      &copy; {year} Todiane Shop. All rights reserved.
    </div>
  </div>
</footer>
